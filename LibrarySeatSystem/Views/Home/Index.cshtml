@{
    ViewData["Title"] = "首页";
    var currentUserName = Context.Session.GetString("CurrentUserName") ?? "张三";
}

<div class="text-center py-5">
    <div class="card-custom mx-auto" style="max-width: 600px; padding: 48px 24px;">
        <h1 style="margin-bottom: 8px;">欢迎使用图书馆座位预约系统</h1>
        <p class="small" style="margin-bottom: 24px; color: var(--text-muted);">当前日期：@DateTime.Now.ToString("yyyy年M月D日 dddd")</p>
        <p class="small" style="margin-bottom: 32px; color: var(--text-muted);">当前体验账号：<strong>@currentUserName</strong></p>

        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a asp-controller="Seat" asp-action="List" class="btn btn-primary" style="min-width: 160px;">查看座位</a>
            <a asp-controller="Reservation" asp-action="My" class="btn btn-outline-secondary" style="min-width: 160px;">我的预约</a>
        </div>
    </div>

    <div class="info-grid mx-auto mt-4" style="max-width: 600px;">
        <div class="info-item">
            <div class="info-label">总座位数</div>
            <div class="info-value">@ViewBag.TotalSeats</div>
        </div>
        <div class="info-item">
            <div class="info-label">可预约</div>
            <div class="info-value text-success-custom">@ViewBag.AvailableSeats</div>
        </div>
        <div class="info-item">
            <div class="info-label">维护中</div>
            <div class="info-value text-warning-custom">@ViewBag.MaintenanceSeats</div>
        </div>
    </div>
</div>
