@{
    ViewData["Title"] = "统计";
}

<h1 style="margin-bottom: 24px;">统计</h1>

<!-- 数据卡片 -->
<div class="info-grid">
    <div class="card-custom text-center" style="padding: 24px;">
        <div class="info-label">总预约数</div>
        <div class="info-value">@ViewBag.TotalCount</div>
    </div>
    <div class="card-custom text-center" style="padding: 24px;">
        <div class="info-label">今日预约数</div>
        <div class="info-value text-primary-custom">@ViewBag.TodayCount</div>
    </div>
    <div class="card-custom text-center" style="padding: 24px;">
        <div class="info-label">有效预约数</div>
        <div class="info-value text-success-custom">@ViewBag.ActiveCount</div>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
    <!-- 热门座位 TOP5 -->
    <div class="card-custom">
        <h3 style="margin-bottom: 16px;">热门座位 TOP5</h3>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>排名</th>
                        <th>座位编号</th>
                        <th>预约次数</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.TopSeats != null)
                    {
                        var rank = 1;
                        foreach (var item in ViewBag.TopSeats)
                        {
                            <tr>
                                <td>@rank</td>
                                <td>@item.Name</td>
                                <td>@item.Count</td>
                            </tr>
                            rank++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 时段分布 -->
    <div class="card-custom">
        <h3 style="margin-bottom: 16px;">时段分布</h3>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>时段</th>
                        <th>预约数</th>
                        <th>占比</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.TimeSlotDistribution != null && (int)ViewBag.TotalForPercentage > 0)
                    {
                        foreach (var item in ViewBag.TimeSlotDistribution)
                        {
                            var percentage = (double)item.Count / (int)ViewBag.TotalForPercentage * 100;
                            <tr>
                                <td>@item.Slot</td>
                                <td>@item.Count</td>
                                <td>@percentage.ToString("F1")%</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
