@{
    ViewData["Title"] = "统计页";
}

<h2>统计页</h2>

<div class="row mt-3">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">总预约数</h5>
                <p class="display-6">@ViewBag.TotalCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">今日预约数</h5>
                <p class="display-6">@ViewBag.TodayCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">有效预约数</h5>
                <p class="display-6">@ViewBag.ActiveCount</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <h4>热门座位 TOP5</h4>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>座位编号</th>
                    <th>预约次数</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.TopSeats != null)
                {
                    foreach (var item in ViewBag.TopSeats)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Count</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h4>时段预约分布</h4>
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>时段</th>
                    <th>预约次数</th>
                    <th>占比</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.TimeSlotDistribution != null && (int)ViewBag.TotalForPercentage > 0)
                {
                    foreach (var item in ViewBag.TimeSlotDistribution)
                    {
                        var percentage = (double)item.Count / (int)ViewBag.TotalForPercentage * 100;
                        <tr>
                            <td>@item.Slot</td>
                            <td>@item.Count</td>
                            <td>@percentage.ToString("F1")%</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
