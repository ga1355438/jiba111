@model List<LibrarySeatSystem.Models.Entities.Reservation>
@{
    ViewData["Title"] = "预约管理";
}

<h1 style="margin-bottom: 24px;">预约管理</h1>

<!-- 筛选栏 -->
<div class="card-custom" style="margin-bottom: 24px;">
    <form method="get" class="filter-bar">
        <div class="filter-item">
            <label class="form-label">日期</label>
            <input type="date" name="date" value="@ViewBag.FilterDate" class="form-control" />
        </div>
        <div class="filter-item">
            <label class="form-label">状态</label>
            <select name="status" class="form-select" style="width: 150px;">
                <option value="">全部</option>
                @if (ViewBag.FilterStatus?.ToString() == "0")
                {
                    <option value="0" selected>已预约</option>
                }
                else
                {
                    <option value="0">已预约</option>
                }
                @if (ViewBag.FilterStatus?.ToString() == "2")
                {
                    <option value="2" selected>已取消</option>
                }
                else
                {
                    <option value="2">已取消</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary">查询</button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="card-custom">
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <div style="font-size: 16px;">暂无预约记录</div>
        </div>
    </div>
}
else
{
    <!-- 桌面端表格 -->
    <div class="card-custom table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>座位编号</th>
                    <th>预约人</th>
                    <th>预约日期</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>创建时间</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Seat?.Name</td>
                        <td>@r.UserName</td>
                        <td>@r.ReserveDate.ToString("yyyy-MM-dd")</td>
                        <td>@r.TimeSlot</td>
                        <td>
                            @if (r.Status == LibrarySeatSystem.Models.Enums.ReservationStatus.Reserved)
                            {
                                <span class="badge badge-reserved">已预约</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled">已取消</span>
                            }
                        </td>
                        <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 手机端卡片 -->
    <div class="mobile-cards" style="display: none;">
        @foreach (var r in Model)
        {
            <div class="card-custom mb-3">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                    <span style="font-size: 16px; font-weight: 600; color: var(--text-title);">@r.Seat?.Name - @r.UserName</span>
                    @if (r.Status == LibrarySeatSystem.Models.Enums.ReservationStatus.Reserved)
                    {
                        <span class="badge badge-reserved">已预约</span>
                    }
                    else
                    {
                        <span class="badge badge-cancelled">已取消</span>
                    }
                </div>
                <div style="font-size: 14px; color: var(--text-muted); margin-bottom: 4px;">@r.ReserveDate.ToString("yyyy-MM-dd") | @r.TimeSlot</div>
                <div style="font-size: 12px; color: var(--text-muted);">创建时间：@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center mt-4">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="ReservationIndex" asp-route-page="@i" asp-route-date="@ViewBag.FilterDate" asp-route-status="@ViewBag.FilterStatus" style="@(i == ViewBag.CurrentPage ? "background-color: var(--primary); border-color: var(--primary);" : "")">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
