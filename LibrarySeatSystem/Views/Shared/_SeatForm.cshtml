@model LibrarySeatSystem.Models.Entities.Seat

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="@(Model.Id == 0 ? "SeatCreate" : "SeatEdit")" method="post" class="mt-3" style="max-width: 500px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />

    <div class="mb-3">
        <label class="form-label">座位编号</label>
        <input asp-for="Name" class="form-control" required />
    </div>
    <div class="mb-3">
        <label class="form-label">位置</label>
        <input asp-for="Location" class="form-control" required />
    </div>
    <div class="mb-3 form-check">
        <input asp-for="HasPower" class="form-check-input" />
        <label class="form-check-label">有电源</label>
    </div>
    <div class="mb-3">
        <label class="form-label">状态</label>
        <select asp-for="Status" class="form-select">
            <option value="0">可用</option>
            <option value="1">维护中</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
    <a asp-action="SeatIndex" class="btn btn-outline-secondary ms-2">取消</a>
</form>
