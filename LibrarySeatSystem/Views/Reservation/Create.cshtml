@model LibrarySeatSystem.Models.Entities.Reservation
@{
    ViewData["Title"] = "预约座位";
    var seat = (LibrarySeatSystem.Models.Entities.Seat)ViewBag.Seat;
    var timeSlots = (string[])ViewBag.TimeSlots;
}

<h2>预约座位</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="card mt-3">
    <div class="card-body">
        <p><strong>座位编号：</strong>@seat.Name</p>
        <p><strong>位置：</strong>@seat.Location</p>
        <p><strong>当前用户：</strong>@ViewBag.UserName</p>
    </div>
</div>

<form asp-action="Create" method="post" class="mt-3">
    <input type="hidden" asp-for="SeatId" />

    <div class="mb-3">
        <label class="form-label">预约日期</label>
        <input asp-for="ReserveDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>

    <div class="mb-3">
        <label class="form-label">时段</label>
        <select asp-for="TimeSlot" class="form-select">
            @foreach (var slot in timeSlots)
            {
                <option value="@slot">@slot</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">提交预约</button>
    <a asp-controller="Seat" asp-action="Detail" asp-route-id="@seat.Id" class="btn btn-outline-secondary ms-2">返回</a>
</form>
