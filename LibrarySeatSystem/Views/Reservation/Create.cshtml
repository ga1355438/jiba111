@model LibrarySeatSystem.Models.Entities.Reservation
@{
    ViewData["Title"] = "预约提交";
    var seat = (LibrarySeatSystem.Models.Entities.Seat)ViewBag.Seat;
    var timeSlots = (string[])ViewBag.TimeSlots;
}

<a asp-controller="Seat" asp-action="Detail" asp-route-id="@seat.Id" style="display: inline-flex; align-items: center; gap: 4px; margin-bottom: 16px; font-size: 14px;">&larr; 返回详情</a>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 24px;">
    <!-- 左侧：座位信息卡片 -->
    <div class="card-custom">
        <h3 style="margin-bottom: 16px;">预约信息</h3>
        <div style="margin-bottom: 16px;">
            <div style="font-size: 14px; font-weight: 500; color: var(--text-body); margin-bottom: 4px;">座位编号</div>
            <div>@seat.Name</div>
        </div>
        <div style="margin-bottom: 16px;">
            <div style="font-size: 14px; font-weight: 500; color: var(--text-body); margin-bottom: 4px;">位置</div>
            <div>@seat.Location</div>
        </div>
        <div>
            <div style="font-size: 14px; font-weight: 500; color: var(--text-body); margin-bottom: 4px;">当前用户</div>
            <div>@ViewBag.UserName</div>
        </div>
    </div>

    <!-- 右侧：预约表单 -->
    <div class="card-custom">
        <h3 style="margin-bottom: 16px;">提交预约</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="SeatId" />

            <div class="mb-3">
                <label class="form-label">选择日期</label>
                <input asp-for="ReserveDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <div style="font-size: 14px; color: var(--text-muted); margin-top: 4px;">只能预约今天及以后的日期</div>
            </div>

            <div class="mb-3">
                <label class="form-label">选择时段</label>
                <select asp-for="TimeSlot" class="form-select">
                    @foreach (var slot in timeSlots)
                    {
                        <option value="@slot">@slot</option>
                    }
                </select>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 24px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">提交预约</button>
                <a asp-controller="Seat" asp-action="Detail" asp-route-id="@seat.Id" class="btn btn-outline-secondary" style="flex: 1;">返回</a>
            </div>
        </form>
    </div>
</div>
