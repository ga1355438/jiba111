@model List<LibrarySeatSystem.Models.Entities.Reservation>
@{
    ViewData["Title"] = "我的预约";
}

<h2>我的预约</h2>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">暂无预约记录</div>
}
else
{
    <table class="table table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>座位编号</th>
                <th>位置</th>
                <th>预约日期</th>
                <th>时段</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Seat?.Name</td>
                    <td>@r.Seat?.Location</td>
                    <td>@r.ReserveDate.ToString("yyyy-MM-dd")</td>
                    <td>@r.TimeSlot</td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <span class="badge bg-success">已预约</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">已取消</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('确定取消此预约吗？')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">取消</button>
                            </form>
                        }
                        else
                        {
                            <span>--</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<form asp-controller="Reservation" asp-action="SwitchUser" method="post" class="mt-3">
    <label class="form-label">切换体验账号：</label>
    <select name="userName" class="form-select d-inline-block w-auto">
        <option value="张三">张三</option>
        <option value="李四">李四</option>
        <option value="王五">王五</option>
    </select>
    <button type="submit" class="btn btn-sm btn-outline-primary ms-2">切换</button>
</form>
