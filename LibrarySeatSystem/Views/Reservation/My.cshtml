@model List<LibrarySeatSystem.Models.Entities.Reservation>
@{
    ViewData["Title"] = "我的预约";
}

<h1 style="margin-bottom: 24px;">我的预约</h1>

@if (!Model.Any())
{
    <div class="card-custom">
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <div style="font-size: 16px;">暂无预约记录</div>
        </div>
    </div>
}
else
{
    <!-- 桌面端表格 -->
    <div class="card-custom table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>座位编号</th>
                    <th>位置</th>
                    <th>预约日期</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Seat?.Name</td>
                        <td>@r.Seat?.Location</td>
                        <td>@r.ReserveDate.ToString("yyyy-MM-dd")</td>
                        <td>@r.TimeSlot</td>
                        <td>
                            @if (r.Status == 0)
                            {
                                <span class="badge badge-reserved">已预约</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled">已取消</span>
                            }
                        </td>
                        <td>
                            @if (r.Status == 0)
                            {
                                <form asp-action="Cancel" asp-route-id="@r.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('确定取消此预约吗？取消后无法恢复。')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">取消</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 手机端卡片 -->
    <div class="mobile-cards" style="display: none;">
        @foreach (var r in Model)
        {
            <div class="card-custom mb-3">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                    <span style="font-size: 16px; font-weight: 600; color: var(--text-title);">@r.Seat?.Name</span>
                    @if (r.Status == 0)
                    {
                        <span class="badge badge-reserved">已预约</span>
                    }
                    else
                    {
                        <span class="badge badge-cancelled">已取消</span>
                    }
                </div>
                <div style="font-size: 14px; color: var(--text-muted); margin-bottom: 12px;">@r.ReserveDate.ToString("yyyy-MM-dd") | @r.TimeSlot</div>
                @if (r.Status == 0)
                {
                    <form asp-action="Cancel" asp-route-id="@r.Id" method="post"
                          onsubmit="return confirm('确定取消此预约吗？取消后无法恢复。')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">取消</button>
                    </form>
                }
            </div>
        }
    </div>
}

<form asp-controller="Reservation" asp-action="SwitchUser" method="post" class="mt-4">
    <label class="form-label">切换体验账号：</label>
    <select name="userName" class="form-select d-inline-block w-auto">
        <option value="张三">张三</option>
        <option value="李四">李四</option>
        <option value="王五">王五</option>
    </select>
    <button type="submit" class="btn btn-sm btn-outline-primary ms-2">切换</button>
</form>
