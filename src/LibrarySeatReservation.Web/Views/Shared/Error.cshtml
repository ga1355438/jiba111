@model ErrorViewModel
@{
    ViewData["Title"] = "出错了";
}

<div class="text-center mt-5">
    <h1 class="text-danger">出错了</h1>
    <p class="lead">处理您的请求时发生了错误。</p>

    @if (Model.ShowRequestId)
    {
        <p><strong>请求 ID：</strong><code>@Model.RequestId</code></p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">返回首页</a>
</div>
