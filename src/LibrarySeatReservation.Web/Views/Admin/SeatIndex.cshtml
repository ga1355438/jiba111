@model List<LibrarySeatReservation.Web.Models.Entities.Seat>
@{
    ViewData["Title"] = "座位管理";
    Layout = "_AdminLayout";
}

<h2>座位管理</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<a asp-action="SeatCreate" class="btn btn-primary mb-3">新增座位</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>名称</th>
            <th>位置</th>
            <th>电源</th>
            <th>状态</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var seat in Model)
        {
            <tr>
                <td>@seat.Id</td>
                <td>@seat.Name</td>
                <td>@seat.Location</td>
                <td>@(seat.HasPower ? "有" : "无")</td>
                <td>
                    @if (seat.Status == 0)
                    {
                        <span class="badge badge-available">可用</span>
                    }
                    else
                    {
                        <span class="badge badge-maintenance">维护中</span>
                    }
                </td>
                <td>
                    <a asp-action="SeatEdit" asp-route-id="@seat.Id" class="btn btn-sm btn-outline-primary">编辑</a>
                    <form method="post" asp-action="SeatDelete" asp-route-id="@seat.Id" class="d-inline"
                          onsubmit="return confirm('确定删除座位 @seat.Name 吗？')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">删除</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
