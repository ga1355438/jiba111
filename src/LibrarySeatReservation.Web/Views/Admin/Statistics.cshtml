@using LibrarySeatReservation.Web.Constants
@{
    ViewData["Title"] = "统计";
    var stats = ViewBag.Stats;
    Layout = "_AdminLayout";
}

<h2>统计</h2>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-muted">总预约数</h5>
                <p class="display-6">@stats.TotalCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-muted">今日预约</h5>
                <p class="display-6">@stats.TodayCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-muted">有效预约</h5>
                <p class="display-6">@stats.ActiveCount</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">热门座位 TOP5</div>
            <div class="card-body">
                @if (((List<dynamic>)stats.TopSeats).Any())
                {
                    <table class="table table-sm">
                        <thead><tr><th>座位名称</th><th>预约次数</th></tr></thead>
                        <tbody>
                            @foreach (var s in (List<dynamic>)stats.TopSeats)
                            {
                                <tr><td>@s.SeatName</td><td>@s.Count</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">暂无数据</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">时段分布</div>
            <div class="card-body">
                @if (((List<dynamic>)stats.TimeSlotDist).Any())
                {
                    <table class="table table-sm">
                        <thead><tr><th>时段</th><th>预约次数</th></tr></thead>
                        <tbody>
                            @foreach (var s in (List<dynamic>)stats.TimeSlotDist)
                            {
                                <tr>
                                    <td>@(TimeSlots.DisplayNames.ContainsKey((string)s.Slot) ? TimeSlots.DisplayNames[(string)s.Slot] : s.Slot)</td>
                                    <td>@s.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">暂无数据</p>
                }
            </div>
        </div>
    </div>
</div>
