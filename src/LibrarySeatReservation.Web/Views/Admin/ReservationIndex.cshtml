@model List<LibrarySeatReservation.Web.Models.Entities.Reservation>
@using LibrarySeatReservation.Web.Constants
@{
    ViewData["Title"] = "预约管理";
    Layout = "_AdminLayout";
}

<h2>预约管理</h2>

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <label class="form-label">日期</label>
        <input type="date" class="form-control" name="date" value="@ViewBag.FilterDate" />
    </div>
    <div class="col-auto">
        <label class="form-label">状态</label>
        <select class="form-select" name="status">
            <option value="">全部</option>
            @if (ViewBag.FilterStatus?.ToString() == "0") { <option value="0" selected>已预约</option> } else { <option value="0">已预约</option> }
            @if (ViewBag.FilterStatus?.ToString() == "1") { <option value="1" selected>已签到</option> } else { <option value="1">已签到</option> }
            @if (ViewBag.FilterStatus?.ToString() == "2") { <option value="2" selected>已取消</option> } else { <option value="2">已取消</option> }
            @if (ViewBag.FilterStatus?.ToString() == "3") { <option value="3" selected>已过期</option> } else { <option value="3">已过期</option> }
        </select>
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-primary">筛选</button>
        <a asp-action="ReservationIndex" class="btn btn-outline-secondary">重置</a>
    </div>
</form>

<p>共 @ViewBag.TotalItems 条记录，第 @ViewBag.CurrentPage / @ViewBag.TotalPages 页</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>座位</th>
            <th>用户</th>
            <th>日期</th>
            <th>时段</th>
            <th>状态</th>
            <th>创建时间</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@(r.Seat?.Name ?? "-")</td>
                    <td>@r.UserName</td>
                    <td>@r.ReserveDate.ToString("yyyy-MM-dd")</td>
                    <td>@(TimeSlots.DisplayNames.ContainsKey(r.TimeSlot) ? TimeSlots.DisplayNames[r.TimeSlot] : r.TimeSlot)</td>
                    <td>
                        @if (r.Status == 0) { <span class="badge badge-reserved">已预约</span> }
                        else if (r.Status == 1) { <span class="badge badge-checkedin">已签到</span> }
                        else if (r.Status == 2) { <span class="badge badge-cancelled">已取消</span> }
                        else { <span class="badge badge-expired">已过期</span> }
                    </td>
                    <td>@r.CreatedAt.ToString("MM-dd HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">暂无预约记录</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.Any())
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @((int)ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=1&date=@ViewBag.FilterDate&status=@ViewBag.FilterStatus">首页</a>
            </li>
            <li class="page-item @((int)ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="?page=@((int)ViewBag.CurrentPage - 1)&date=@ViewBag.FilterDate&status=@ViewBag.FilterStatus">上一页</a>
            </li>
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @((int)ViewBag.CurrentPage == i ? "active" : "")">
                    <a class="page-link" href="?page=@i&date=@ViewBag.FilterDate&status=@ViewBag.FilterStatus">@i</a>
                </li>
            }
            <li class="page-item @((int)ViewBag.CurrentPage == (int)ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@((int)ViewBag.CurrentPage + 1)&date=@ViewBag.FilterDate&status=@ViewBag.FilterStatus">下一页</a>
            </li>
            <li class="page-item @((int)ViewBag.CurrentPage == (int)ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" href="?page=@((int)ViewBag.TotalPages)&date=@ViewBag.FilterDate&status=@ViewBag.FilterStatus">末页</a>
            </li>
        </ul>
    </nav>
}
