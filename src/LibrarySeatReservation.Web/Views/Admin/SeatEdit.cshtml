@model LibrarySeatReservation.Web.Models.Entities.Seat
@{
    ViewData["Title"] = "编辑座位";
    Layout = "_AdminLayout";
}

<h2>编辑座位</h2>

<form method="post" class="mt-3" style="max-width:500px">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="mb-3">
        <label for="Name" class="form-label">座位名称</label>
        <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" required />
    </div>
    <div class="mb-3">
        <label for="Location" class="form-label">位置</label>
        <input type="text" class="form-control" id="Location" name="Location" value="@Model.Location" required />
    </div>
    <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="HasPower" name="HasPower" value="true"
               @(Model.HasPower ? "checked" : "") />
        <label class="form-check-label" for="HasPower">有电源</label>
    </div>
    <div class="mb-3">
        <label for="Status" class="form-label">状态</label>
        <select class="form-select" id="Status" name="Status">
            @if (Model.Status == 0) { <option value="0" selected>可用</option> } else { <option value="0">可用</option> }
            @if (Model.Status == 1) { <option value="1" selected>维护中</option> } else { <option value="1">维护中</option> }
        </select>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
    <a asp-action="SeatIndex" class="btn btn-outline-secondary">取消</a>
</form>
