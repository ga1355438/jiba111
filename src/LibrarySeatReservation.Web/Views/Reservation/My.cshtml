@model List<LibrarySeatReservation.Web.Models.Entities.Reservation>
@using LibrarySeatReservation.Web.Constants
@{
    ViewData["Title"] = "我的预约";
}

<h2>我的预约</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>当前用户：<strong>@ViewBag.CurrentUserName</strong></p>

@if (!Model.Any())
{
    <div class="text-center py-4">
        <p class="text-muted mb-2">暂无预约记录</p>
        <a asp-controller="Seat" asp-action="List" class="btn btn-primary btn-sm">去预约座位</a>
    </div>
}
else
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>座位</th>
                <th>日期</th>
                <th>时段</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@(r.Seat?.Name ?? "-")</td>
                    <td>@r.ReserveDate.ToString("yyyy-MM-dd")</td>
                    <td>@(TimeSlots.DisplayNames.ContainsKey(r.TimeSlot) ? TimeSlots.DisplayNames[r.TimeSlot] : r.TimeSlot)</td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <span class="badge badge-reserved">已预约</span>
                        }
                        else if (r.Status == 2)
                        {
                            <span class="badge badge-cancelled">已取消</span>
                        }
                        else
                        {
                            <span class="badge badge-checkedin">状态@r.Status</span>
                        }
                    </td>
                    <td>
                        @if (r.Status == 0)
                        {
                            <form method="post" asp-action="Cancel" asp-route-id="@r.Id"
                                  onsubmit="return confirm('确定取消此预约吗？')">
                                <button type="submit" class="btn btn-danger btn-sm">取消</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
